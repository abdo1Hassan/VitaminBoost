{
  "$schema": "https://schemas.tokens.studio/latest/tokens-schema.json",
  "$metadata": {
    "tokenSetOrder": ["core", "light", "dark"]
  },
  "core": {
    "font": {
      "display": { "value": "Decathlon Display, Space Grotesk, system-ui, sans-serif", "type": "fontFamilies" },
      "text":    { "value": "Decathlon Text, DM Sans, system-ui, sans-serif", "type": "fontFamilies" },
      "mono":    { "value": "JetBrains Mono, ui-monospace, monospace", "type": "fontFamilies" }
    },
    "weight": {
      "regular":  { "value": "400", "type": "fontWeights" },
      "medium":   { "value": "500", "type": "fontWeights" },
      "semibold": { "value": "600", "type": "fontWeights" },
      "bold":     { "value": "700", "type": "fontWeights" }
    },
    "size": {
      "xs":  { "value": "12", "type": "fontSizes" },
      "sm":  { "value": "14", "type": "fontSizes" },
      "md":  { "value": "16", "type": "fontSizes" },
      "lg":  { "value": "18", "type": "fontSizes" },
      "xl":  { "value": "20", "type": "fontSizes" },
      "2xl": { "value": "24", "type": "fontSizes" },
      "3xl": { "value": "32", "type": "fontSizes" },
      "4xl": { "value": "48", "type": "fontSizes" },
      "5xl": { "value": "64", "type": "fontSizes" }
    },
    "spacing": {
      "0": { "value": "0", "type": "spacing" },
      "1": { "value": "4", "type": "spacing" },
      "2": { "value": "8", "type": "spacing" },
      "3": { "value": "12", "type": "spacing" },
      "4": { "value": "16", "type": "spacing" },
      "5": { "value": "24", "type": "spacing" },
      "6": { "value": "32", "type": "spacing" },
      "7": { "value": "48", "type": "spacing" },
      "8": { "value": "64", "type": "spacing" }
    },
    "radius": {
      "sm":   { "value": "8",  "type": "borderRadius" },
      "md":   { "value": "10", "type": "borderRadius" },
      "lg":   { "value": "12", "type": "borderRadius" },
      "xl":   { "value": "16", "type": "borderRadius" },
      "2xl":  { "value": "20", "type": "borderRadius" },
      "3xl":  { "value": "24", "type": "borderRadius" },
      "full": { "value": "9999", "type": "borderRadius" }
    },
    "motion": {
      "fast": { "value": "180", "type": "duration", "description": "Taps, segmented control, chip hover" },
      "base": { "value": "300", "type": "duration", "description": "Lift, tilt, magnetic, ripple, fade-up" },
      "slow": { "value": "450", "type": "duration", "description": "Modals, enters, shake (deliberate)" },
      "spring": { "value": "cubic-bezier(0.22, 1, 0.36, 1)", "type": "cubicBezier" }
    },
    "shadow": {
      "xs":      { "value": { "x": "0", "y": "1",  "blur": "2",  "spread": "0", "color": "rgba(28,35,73,0.06)", "type": "dropShadow" }, "type": "boxShadow" },
      "sm":      { "value": { "x": "0", "y": "2",  "blur": "8",  "spread": "0", "color": "rgba(28,35,73,0.06)", "type": "dropShadow" }, "type": "boxShadow" },
      "md":      { "value": { "x": "0", "y": "8",  "blur": "24", "spread": "-8","color": "rgba(28,35,73,0.12)", "type": "dropShadow" }, "type": "boxShadow" },
      "lg":      { "value": { "x": "0", "y": "20", "blur": "48", "spread": "-12","color":"rgba(28,35,73,0.18)", "type": "dropShadow" }, "type": "boxShadow" },
      "glow":    { "value": { "x": "0", "y": "12", "blur": "32", "spread": "-8","color": "rgba(54,67,186,0.32)", "type": "dropShadow" }, "type": "boxShadow" },
      "ai-glow": { "value": { "x": "0", "y": "16", "blur": "40", "spread": "-12","color":"rgba(120,82,224,0.40)", "type": "dropShadow" }, "type": "boxShadow" }
    }
  },
  "light": {
    "color": {
      "background":            { "value": "#FAFBFD", "type": "color" },
      "foreground":            { "value": "#11132A", "type": "color" },
      "surface":               { "value": "#FFFFFF", "type": "color" },
      "card":                  { "value": "#FFFFFF", "type": "color" },
      "muted":                 { "value": "#F1F2F6", "type": "color" },
      "muted-foreground":      { "value": "#5F6580", "type": "color" },
      "border":                { "value": "#E2E4ED", "type": "color" },

      "primary":               { "value": "#3643BA", "type": "color", "description": "Decathlon Blue — primary actions ONLY" },
      "primary-foreground":    { "value": "#FAFBFD", "type": "color" },
      "accent":                { "value": "#2BA86A", "type": "color", "description": "Green — features, sustainability (not buttons)" },
      "accent-foreground":     { "value": "#FAFBFD", "type": "color" },
      "commercial":            { "value": "#E14B1C", "type": "color", "description": "Promo / discount" },
      "commercial-foreground": { "value": "#FAFBFD", "type": "color" },
      "pop":                   { "value": "#E2418E", "type": "color", "description": "Micro-delight only" },
      "pop-foreground":        { "value": "#FAFBFD", "type": "color" },
      "ai":                    { "value": "#7852E0", "type": "color", "description": "AI-generated content & copilots" },
      "ai-foreground":         { "value": "#FAFBFD", "type": "color" },

      "success":               { "value": "#2EA862", "type": "color" },
      "warning":               { "value": "#E2A93C", "type": "color" },
      "info":                  { "value": "#2F73C4", "type": "color" },
      "destructive":           { "value": "#D9402B", "type": "color" }
    }
  },
  "dark": {
    "color": {
      "background":         { "value": "#13162B", "type": "color" },
      "foreground":         { "value": "#F4F5FA", "type": "color" },
      "surface":            { "value": "#1B1F38", "type": "color" },
      "card":               { "value": "#1B1F38", "type": "color" },
      "muted":              { "value": "#252A47", "type": "color" },
      "muted-foreground":   { "value": "#9DA3C2", "type": "color" },
      "border":             { "value": "#2D3252", "type": "color" },

      "primary":            { "value": "#6F7BE6", "type": "color" },
      "primary-foreground": { "value": "#11132A", "type": "color" },
      "accent":             { "value": "#4FCB8F", "type": "color" },
      "pop":                { "value": "#F265A8", "type": "color" },
      "ai":                 { "value": "#9277F0", "type": "color" }
    }
  }
}
